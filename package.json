{
  "name": "r6-data.js",
  "version": "3.1.0",
  "description": "R6 Siege (Rainbow Six Siege) API wrapper for player stats, operators, maps, ranks, seasons, charms, skins, game datas and ban status. Last Updated Y11S1",
  "main": "src/index.js",
  "type": "commonjs",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./src/index.js",
      "require": "./src/index.js",
      "default": "./src/index.js"
    }
  },
  "types": "./index.d.ts",
  "files": [
    "src/",
    "index.d.ts",
    "tsconfig.json",
    "types/",
    "README.md"
  ],
  "scripts": {
    "test": "node -e \"console.log('no tests yet')\"",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mazeor9/r6-data.js"
  },
  "homepage": "https://r6data.eu/",
  "bugs": {
    "url": "https://github.com/mazeor9/r6-data.js/issues"
  },
  "funding": "https://buymeacoffee.com/mazeor",
  "keywords": [
    "r6",
    "rainbow-six-siege",
    "r6-api",
    "r6-stats",
    "siege-api",
    "rainbow-six",
    "ubisoft",
    "gaming-api",
    "player-stats",
    "r6-data",
    "siege-stats",
    "r6-tracker",
    "operators",
    "maps",
    "ranks",
    "r6s stats"
  ],
  "author": "mazeor",
  "license": "MIT",
  "dependencies": {
    "ms": "^2.1.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "typescript": "^6.0.2"
  }
}
